Query {
    spanset: Filter(
        SpansetFilter {
            body: Some(
                Comparison {
                    field: Attribute {
                        scope: Span,
                        key: "http.route",
                    },
                    op: Re,
                    value: String(
                        "/api/v\\d+/.*",
                    ),
                },
            ),
        },
    ),
    pipeline: [],
}
