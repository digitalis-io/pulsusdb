Query {
    spanset: Filter(
        SpansetFilter {
            body: Some(
                Comparison {
                    field: Attribute {
                        scope: Unscoped,
                        key: "http.status_code",
                    },
                    op: Eq,
                    value: Number(
                        "200",
                    ),
                },
            ),
        },
    ),
    pipeline: [],
}
