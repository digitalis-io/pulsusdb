Query {
    spanset: Filter(
        SpansetFilter {
            body: Some(
                Comparison {
                    field: Attribute {
                        scope: Unscoped,
                        key: "a",
                    },
                    op: Eq,
                    value: Number(
                        "1",
                    ),
                },
            ),
        },
    ),
    pipeline: [
        By {
            fields: [
                Attribute {
                    scope: Resource,
                    key: "service.name",
                },
            ],
        },
    ],
    hints: [],
}
