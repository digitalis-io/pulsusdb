Query {
    spanset: Filter(
        SpansetFilter {
            body: Some(
                Comparison {
                    field: Attribute {
                        scope: Resource,
                        key: "service.name",
                    },
                    op: Eq,
                    value: String(
                        "checkout",
                    ),
                },
            ),
        },
    ),
    pipeline: [
        Aggregate {
            op: Avg,
            field: Some(
                Intrinsic(
                    Duration,
                ),
            ),
            cmp: Gt,
            value: Duration(
                Duration(
                    100000000,
                ),
            ),
        },
    ],
}
