Query {
    spanset: Filter(
        SpansetFilter {
            body: Some(
                Comparison {
                    field: Attribute {
                        scope: Unscoped,
                        key: "a",
                    },
                    op: Eq,
                    value: Number(
                        "1",
                    ),
                },
            ),
        },
    ),
    pipeline: [
        Metric(
            MetricStage {
                func: Rate,
                by: [
                    Attribute {
                        scope: Resource,
                        key: "service.name",
                    },
                ],
                hints: [],
                result_filter: None,
            },
        ),
    ],
    hints: [],
}
