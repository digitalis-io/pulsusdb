Query {
    spanset: Filter(
        SpansetFilter {
            body: Some(
                Comparison {
                    field: Attribute {
                        scope: Span,
                        key: "http.url",
                    },
                    op: Re,
                    value: String(
                        "/api/.*",
                    ),
                },
            ),
        },
    ),
    pipeline: [],
    hints: [],
}
