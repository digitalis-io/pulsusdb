    {
      "name": "annotations",
      "status": "scheduled",
      "issue": "M6-08",
      "probe_rationale": "annotation assertions are .test directives (expect warn/info/...), not a PromQL expression \u2014 enforcement lives in the skip-manifest drift test until M6-08 activates the expect-directive files"
    },
    {
      "name": "native-histogram-values",
      "status": "deferred",
      "rationale": "native histograms \u2014 M7 (#22)",
      "probe_rationale": "native-histogram sample literals ({{...}}) exist only in .test series syntax; no float-era PromQL expression can exercise them \u2014 enforcement lives in the skip-manifest drift test until #22"
    },
    {
      "name": "type-and-unit-labels",
      "status": "scheduled",
      "issue": "M6-08",
      "probe_rationale": "PROM-39 __type__/__unit__ metadata-label semantics are label-propagation behaviour on computed values, not a distinct expression form \u2014 no PromQL probe can isolate them; M6-08 evaluates-and-decides (issue #64 adjudication) with the 9 upstream/type_and_unit.test eval-divergences ledger entries as its input"
    }
  ]
