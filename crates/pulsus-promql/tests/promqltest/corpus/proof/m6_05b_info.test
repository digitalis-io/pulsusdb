# Issue #82 (M6-05b) proof corpus — witness cases for the experimental
# info() metadata-join (function-coverage.json points its `witness` at a
# query below; the coverage drift test replays this file and requires it
# to pass). Every load/eval block up to the "issue #82 Δ1 additions"
# marker transcribes the byte-frozen vendored `upstream/info.test`
# (Prometheus v3.13.0 @ 40af9c2, promql/promqltest/testdata/info.test)
# verbatim, MINUS its single native-histogram case (`info(metric,
# {__name__="histogram"})` `expect fail` — blocked on #22 with the rest
# of the native-histogram surface); that vendored file itself stays
# skip-manifested wholesale behind the native-histogram sample syntax.
# The driver plans with the experimental gate ON (upstream promqltest's
# own EnableExperimentalFunctions), which info() requires.
#
# Pinned semantics this file exercises end-to-end:
#   - default target_info family; explicit/regex/negated __name__
#     selection (effectiveInfoNameMatchers' three branches);
#   - identifying labels hard-coded ["instance","job"]; signature =
#     info-metric name + the PRESENT identifying labels;
#   - data-label inclusion limited to the matcher-named keys; labels
#     already on the base are skipped; empty-string-matcher fallback
#     (drop iff some data matcher rejects "");
#   - info-family base series are ignored (passthrough, never enriched,
#     never fallback-dropped);
#   - newest-original-timestamp-wins dedup across overlapping info
#     series; lookback applies to the info side; @/offset copied from
#     arg0's first selector;
#   - the horizon-wide identifying-label narrowing (issue #82 Δ1 + the
#     round-2 adjudication): idLblValues built once from the full
#     non-ignored base matrix; empty ⇒ the info.go:183 short-circuit
#     (ID-less base × ID-less info never enriches); an info series
#     carrying an out-of-set value OR MISSING a constrained identifying
#     label is excluded BEFORE dedup (absence ≠ wildcard);
#   - the pinned `conflicting label: x` error (info.go:446).
#
# Every case in this file was additionally replayed byte-for-byte
# against the pinned upstream engine (go test with this file dropped
# into promql/promqltest at 40af9c2) — including the Δ1 additions, which
# have no vendored counterpart; see the issue #82 implementation notes.

load 5m
	metric{instance="a", job="1", label="value"} 0 1 2
	metric_not_matching_target_info{instance="a", job="2", label="value"} 0 1 2
	metric_with_overlapping_label{instance="a", job="1", label="value", data="base"} 0 1 2
	target_info{instance="a", job="1", data="info", another_data="another info"} 1 1 1
	build_info{instance="a", job="1", build_data="build"} 1 1 1

# Include one info metric data label.
eval range from 0m to 10m step 5m info(metric, {data=~".+"})
	metric{data="info", instance="a", job="1", label="value"} 0 1 2

# Include all info metric data labels.
eval range from 0m to 10m step 5m info(metric)
	metric{data="info", instance="a", job="1", label="value", another_data="another info"} 0 1 2

# Try including all info metric data labels, but non-matching identifying labels.
eval range from 0m to 10m step 5m info(metric_not_matching_target_info)
	metric_not_matching_target_info{instance="a", job="2", label="value"} 0 1 2

# Non-matching identifying labels with a data label matcher that matches
# empty string. The series should still be returned unchanged.
eval range from 0m to 10m step 5m info(metric_not_matching_target_info, {data=~".*"})
	metric_not_matching_target_info{instance="a", job="2", label="value"} 0 1 2

# Non-matching identifying labels with a data label matcher that doesn't
# match empty string. The series should be dropped since no info series
# matches and the matcher requires a non-empty value.
eval range from 0m to 10m step 5m info(metric_not_matching_target_info, {data=~".+"})

# A data label matcher not matching empty labels and no matching info
# series: the metric is dropped.
eval range from 0m to 10m step 5m info(metric, {non_existent=~".+"})

# A data matcher accepting empty labels. The metric is returned unchanged
# since non_existent doesn't exist on target_info but the matcher accepts
# empty strings.
eval range from 0m to 10m step 5m info(metric, {non_existent=~".*"})
	metric{instance="a", job="1", label="value"} 0 1 2

# Info series data labels overlapping with those of base series are ignored.
eval range from 0m to 10m step 5m info(metric_with_overlapping_label)
	metric_with_overlapping_label{data="base", instance="a", job="1", label="value", another_data="another info"} 0 1 2

# Filtering by a label that exists on both base metric and target_info
# (data="base" on base, data="info" on target_info — the filter matches
# target_info; the base keeps its own value).
eval range from 0m to 10m step 5m info(metric_with_overlapping_label, {data="info"})
	metric_with_overlapping_label{data="base", instance="a", job="1", label="value"} 0 1 2

# Same, with a regex matcher.
eval range from 0m to 10m step 5m info(metric_with_overlapping_label, {data=~".+"})
	metric_with_overlapping_label{data="base", instance="a", job="1", label="value"} 0 1 2

# Filtering by a label that exists on both base metric and target_info
# with the same value: only the instance label is considered for
# inclusion, and it already exists on the base.
eval range from 0m to 10m step 5m info(metric_with_overlapping_label, {instance="a"})
	metric_with_overlapping_label{data="base", instance="a", job="1", label="value"} 0 1 2

# Include data labels from target_info specifically.
eval range from 0m to 10m step 5m info(metric, {__name__="target_info"})
	metric{data="info", instance="a", job="1", label="value", another_data="another info"} 0 1 2

# Try to include all data labels from a non-existent info metric.
eval range from 0m to 10m step 5m info(metric, {__name__="non_existent"})
	metric{instance="a", job="1", label="value"} 0 1 2

# Try to include a certain data label from a non-existent info metric.
eval range from 0m to 10m step 5m info(metric, {__name__="non_existent", data=~".+"})

# Include data labels from build_info.
eval range from 0m to 10m step 5m info(metric, {__name__="build_info"})
	metric{instance="a", job="1", label="value", build_data="build"} 0 1 2

# Include data labels from build_info and target_info.
eval range from 0m to 10m step 5m info(metric, {__name__=~".+_info"})
	metric{instance="a", job="1", label="value", build_data="build", data="info", another_data="another info"} 0 1 2

# Info metrics themselves are ignored when it comes to enriching with
# info metric data labels — never fallback-dropped either.
eval range from 0m to 10m step 5m info(build_info, {__name__=~".+_info", another_data=~".+"})
	build_info{instance="a", job="1", build_data="build"} 1 1 1

eval range from 0m to 10m step 5m info(build_info, {__name__=~".+_info"})
	build_info{instance="a", job="1", build_data="build"} 1 1 1

# Negated __name__ matcher: the synthetic .+_info regex is prepended, no
# info metric matches, and data=~".+" doesn't match empty — no results.
eval range from 0m to 10m step 5m info(metric, {__name__!~".+_info", data=~".+"})

# Negated __name__ matcher with a matcher that accepts empty labels: the
# base metric is returned unchanged.
eval range from 0m to 10m step 5m info(metric, {__name__!~".+_info", data=~".*"})
	metric{instance="a", job="1", label="value"} 0 1 2

# Negated exact __name__ matcher: excludes target_info, build_info still
# matches (the synthetic .+_info prepend).
eval range from 0m to 10m step 5m info(metric, {__name__!="target_info"})
	metric{instance="a", job="1", label="value", build_data="build"} 0 1 2

# When a base series matches one positive __name__ matcher but not
# another, it is NOT ignored (AND semantics): build_info matches .+_info
# but not target_.+, so it is enriched like a regular metric.
eval range from 0m to 10m step 5m info(build_info, {__name__=~"target_.+", __name__=~".+_info"})
	build_info{instance="a", job="1", build_data="build", data="info", another_data="another info"} 1 1 1

clear

# A base series matching the positive __name__ matcher but excluded by a
# negative one is NOT ignored — enriched like a regular metric.
load 5m
	websvc_thing{instance="a", job="1", label="value"} 0 1 2
	websvc_stuff_info{instance="a", job="1", build_data="build"} 2 3 4
	target_info{instance="a", job="1", data="info", another_data="another info"} 1 1 1

eval range from 0m to 10m step 5m info({__name__=~"websvc_.+"}, {__name__=~".+_info", __name__!~"websvc_.+"})
	websvc_thing{instance="a", job="1", label="value", data="info", another_data="another info"} 0 1 2
	websvc_stuff_info{instance="a", job="1", build_data="build", data="info", another_data="another info"} 2 3 4

clear

load 5m
	metric{instance="a", job="1", label="value"} 0 1 2
	target_info{instance="a", job="1", data="info", another_data="another info"} 1 1 1
	build_info{instance="a", job="1", build_data="build"} 1 1 1
	target_build{instance="a", job="1", build_data="build"} 1 1 1

# Multiple positive __name__ matchers (AND).
eval range from 0m to 10m step 5m info(metric, {__name__=~"target_.+", __name__=~".+_info"})
	metric{instance="a", job="1", label="value", data="info", another_data="another info"} 0 1 2

# A positive and a negative __name__ matcher.
eval range from 0m to 10m step 5m info(metric, {__name__=~".+_info", __name__!~".*build.*"})
	metric{instance="a", job="1", label="value", data="info", another_data="another info"} 0 1 2

clear

# Overlapping target_info series: conflicts are resolved through picking
# the latest sample (newest-original-timestamp-wins dedup).
load 5m
	metric{instance="a", job="1", label="value"} 0 1 2
	target_info{instance="a", job="1", data="info", another_data="another info"} 1 1 _
	target_info{instance="a", job="1", data="updated info", another_data="another info"} _ _ 1

eval range from 0m to 10m step 5m info(metric)
	metric{data="info", instance="a", job="1", label="value", another_data="another info"} 0 1 _
	metric{data="updated info", instance="a", job="1", label="value", another_data="another info"} _ _ 2

clear

# Non-overlapping target_info series (data labels change over time).
load 5m
	metric{instance="a", job="1", label="value"} 0 1 2
	target_info{instance="a", job="1", data="info"} 1 1 stale
	target_info{instance="a", job="1", data="updated info"} _ _ 1

eval range from 0m to 10m step 5m info(metric)
	metric{data="info", instance="a", job="1", label="value"} 0 1 _
	metric{data="updated info", instance="a", job="1", label="value"} _ _ 2

clear

# Samples at timestamps with no matching info series: dropped when a data
# matcher rejects the empty string, unenriched fallback otherwise.
load 5m
	metric{instance="a", job="1", label="value"} 0 1 2
	target_info{instance="a", job="1", data="info"} 1 1 stale

eval range from 0m to 10m step 5m info(metric, {data=~".+"})
	metric{data="info", instance="a", job="1", label="value"} 0 1 _

eval range from 0m to 10m step 5m info(metric, {data=~".*"})
	metric{data="info", instance="a", job="1", label="value"} 0 1 _
	metric{instance="a", job="1", label="value"} _ _ 2

eval range from 0m to 10m step 5m info(metric)
	metric{data="info", instance="a", job="1", label="value"} 0 1 _
	metric{instance="a", job="1", label="value"} _ _ 2

clear

# Series with skipped scrape: lookback works also for the info series;
# @ and offset (copied from arg0's first selector) work with info.
load 1m
	metric{instance="a", job="1", label="value"} 0 _ 2 3 4
	target_info{instance="a", job="1", data="info"} 1 _ 1 1 1

eval range from 1m to 4m step 1m info(metric)
	metric{data="info", instance="a", job="1", label="value"} 0 2 3 4

# Note we pick the timestamp missing a sample; lookback picks the
# previous sample for both sides.
eval range from 1m to 4m step 1m info(metric @ 60)
	metric{data="info", instance="a", job="1", label="value"} 0 0 0 0

eval range from 1m to 4m step 1m info(metric offset 1m)
	metric{data="info", instance="a", job="1", label="value"} 0 0 2 3

clear

# info_metric churn: the enrichment label set changes over time per
# (instance, job) signature.
load 1m
	data_metric{instance="a", job="work"} 10 20 30
	data_metric{instance="b", job="work"} 11 21 31
	info_metric{instance="b", job="work", state="stopped"} 1 1 _
	info_metric{instance="b", job="work", state="running"} _ _ 1
	info_metric{instance="a", job="work", state="running"} 1 1 1

eval range from 0 to 2m step 1m info(data_metric, {__name__="info_metric"})
	data_metric{instance="a", job="work", state="running"} 10 20 30
	data_metric{instance="b", job="work", state="stopped"} 11 21 _
	data_metric{instance="b", job="work", state="running"} _  _ 31

clear

# data_metric churn: a base series goes stale and a relabeled successor
# appears; a matcher-only base selector also matches the info series
# themselves (ignored, passthrough).
load 1m
	data_metric{instance="a", job="work"} 10 20 stale
	data_metric{instance="b", job="work"} 11 21 31
	data_metric{instance="a", job="work", label="new"} _ _ 30
	info_metric{instance="b", job="work", state="stopped"} 1 1 1
	info_metric{instance="a", job="work", state="running"} 1 1 1

eval range from 0 to 2m step 1m info(data_metric, {__name__="info_metric"})
	data_metric{instance="a", job="work", state="running"} 10 20 _
	data_metric{instance="b", job="work", state="stopped"} 11 21 31
	data_metric{instance="a", job="work", state="running", label="new"} _ _ 30

eval range from 0 to 2m step 1m info({job="work"}, {__name__="info_metric"})
	data_metric{instance="a", job="work", state="running"} 10 20 _
	data_metric{instance="b", job="work", state="stopped"} 11 21 31
	data_metric{instance="a", job="work", state="running", label="new"} _ _ 30
	info_metric{instance="b", job="work", state="stopped"} 1 1 1
	info_metric{instance="a", job="work", state="running"} 1 1 1

clear

# Base series without any identifying labels: no info participation
# (idLblValues is empty — the info.go:183 short-circuit).
load 1m
	data_metric{} 1 2 3

eval range from 0 to 2m step 1m info(data_metric, {__name__="info_metric"})
	data_metric{} 1 2 3

clear

load 1m
	data_metric{} 1 2 3
	data_metric{instance="a"} 4 5 6

eval range from 0 to 2m step 1m info(data_metric, {__name__="info_metric"})
	data_metric{} 1 2 3
	data_metric{instance="a"} 4 5 6

clear

load 1m
	data_metric{} 1 2 3
	data_metric{instance="a"} 4 5 6
	data_metric{job="1"} 7 8 9
	data_metric{instance="a", job="1"} 10 20 30

eval range from 0 to 2m step 1m info(data_metric, {__name__="info_metric"})
	data_metric{} 1 2 3
	data_metric{instance="a"} 4 5 6
	data_metric{job="1"} 7 8 9
	data_metric{instance="a", job="1"} 10 20 30

clear

# Inner series missing one identifying label (job) with an info series
# matching on the present one: enrichment still happens (an absent
# identifying label contributes nothing to the signature).
load 1m
	metric{instance="a"} 1 2 3
	custom_info{instance="a", enriched="yes"} 1 1 1

eval range from 0m to 2m step 1m info(metric, {__name__="custom_info"})
	metric{instance="a", enriched="yes"} 1 2 3

clear

# --- issue #82 Δ1 additions (no vendored counterpart; verified against
# --- the pinned upstream engine, see the header) ---

# Short-circuit fidelity: an ID-less base with an ID-less info row
# PRESENT still does not enrich — idLblValues is empty, so the info
# vector does not participate at all (an eval-time join keyed only on
# signatures would wrongly match the two empty signatures).
load 1m
	data_metric{} 1 2 3
	custom_info{enriched="yes"} 1 1 1

eval range from 0 to 2m step 1m info(data_metric, {__name__="custom_info"})
	data_metric{} 1 2 3

clear

# Eligibility fidelity (round-2 finding 1 + Δ1 step 6): info series with
# out-of-set identifying values are excluded BEFORE dedup — the two
# unrelated (zzz, 9) rows collide on signature at equal timestamps and
# would raise the duplicate-series error if they ever reached the dedup;
# and an info series MISSING a constrained identifying label (job here,
# constrained by the second base series) is excluded too — absence is
# not a wildcard, so neither base series is enriched by it.
load 1m
	metric{instance="a", job="1"} 1 2 3
	target_info{instance="a", job="1", data="in_set"} 1 1 1
	target_info{instance="zzz", job="9", data="out_of_set_one"} 1 1 1
	target_info{instance="zzz", job="9", data="out_of_set_two"} 1 1 1

eval range from 0 to 2m step 1m info(metric)
	metric{instance="a", job="1", data="in_set"} 1 2 3

clear

load 1m
	metric{instance="a"} 1 2 3
	metric{instance="a", job="1"} 4 5 6
	custom_info{instance="a", extra="x"} 1 1 1

eval range from 0 to 2m step 1m info(metric, {__name__="custom_info"})
	metric{instance="a"} 1 2 3
	metric{instance="a", job="1"} 4 5 6

clear

# Horizon-wide narrowing discriminator (issue #82 round-1 review, test
# gap c): the job-carrying base series resolves ONLY at the last step,
# but idLblValues is built once from the FULL non-ignored base matrix —
# so the job-less custom_info row is excluded at EVERY step. A per-step
# reconstruction would enrich metric{instance="a"} at the first two
# steps (where no job value exists yet) and diverge.
load 1m
	metric{instance="a"} 1 2 3
	metric{instance="a", job="1"} _ _ 6
	custom_info{instance="a", extra="x"} 1 1 1

eval range from 0 to 2m step 1m info(metric, {__name__="custom_info"})
	metric{instance="a"} 1 2 3
	metric{instance="a", job="1"} _ _ 6

clear

# Delayed name removal through info() (issue #82 round-1 review, test
# gap b): the pin constructs fresh output samples without DropName
# (combineWithInfoVector / combineWithInfoSeries), so a name-dropping
# arg0 (`abs`) re-emerges from info() with its retained __name__ KEPT
# in the final output.
load 1m
	metric{instance="a", job="1"} -1 -2 -3
	target_info{instance="a", job="1", data="info"} 1 1 1

eval range from 0 to 2m step 1m info(abs(metric))
	metric{instance="a", job="1", data="info"} 1 2 3

clear

# Conflicting labels across different info metrics error with the pinned
# message (info.go:446).
load 1m
	metric{instance="a", job="1"} 1 2 3
	target_info{instance="a", job="1", x="from_target"} 1 1 1
	build_info{instance="a", job="1", x="from_build"} 1 1 1

eval range from 0m to 2m step 1m info(metric, {__name__=~".+_info"})
	expect fail regex: conflicting label: x
