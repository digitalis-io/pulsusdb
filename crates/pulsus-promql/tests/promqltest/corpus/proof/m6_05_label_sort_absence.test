# Natural-sort edge vectors (plan v2 Δ2, hand-derived to the ported
# comparator): leading zeros resolve deterministically by the byte-order
# fallback ("01" before "1"), mixed alpha-numeric tokens compare
# chunkwise (a10b2 before a10b10), digits sort before alpha.

load 5m
	natsort_edge{v="01", id="lz"}	0+10x10
	natsort_edge{v="1", id="one"}	0+10x10
	natsort_edge{v="a10b2", id="m2"}	0+10x10
	natsort_edge{v="a10b10", id="m10"}	0+10x10
	natsort_edge{v="x", id="alpha"}	0+10x10

eval_ordered instant at 50m sort_by_label(natsort_edge, "v")
	natsort_edge{id="lz", v="01"} 100
	natsort_edge{id="one", v="1"} 100
	natsort_edge{id="m2", v="a10b2"} 100
	natsort_edge{id="m10", v="a10b10"} 100
	natsort_edge{id="alpha", v="x"} 100

eval_ordered instant at 50m sort_by_label_desc(natsort_edge, "v")
	natsort_edge{id="alpha", v="x"} 100
	natsort_edge{id="m10", v="a10b10"} 100
	natsort_edge{id="m2", v="a10b2"} 100
	natsort_edge{id="one", v="1"} 100
	natsort_edge{id="lz", v="01"} 100

clear

# Cross-metric full-label ties (plan v2 Δ2): two series identical on the
# named label, differing only in __name__ — the fallback compares the
# VIRTUAL full label set with __name__ at its lexical key position. The
# multi-name vector is built with a __name__-writing label_replace (a
# multi-name selector is still planner-unsupported).

load 5m
	tie{kind="bbb", x="1"}	0+10x10
	tie{kind="aaa", x="1"}	0+20x10
	tie_pos{__aa="z", kind="aaa", x="1"}	0+10x10
	tie_pos{__aa="a", kind="zzz", x="1"}	0+20x10

eval_ordered instant at 50m sort_by_label(label_replace(tie, "__name__", "$1", "kind", "(.*)"), "x")
	aaa{kind="aaa", x="1"} 200
	bbb{kind="bbb", x="1"} 100

eval_ordered instant at 50m sort_by_label_desc(label_replace(tie, "__name__", "$1", "kind", "(.*)"), "x")
	bbb{kind="bbb", x="1"} 100
	aaa{kind="aaa", x="1"} 200

# __name__ sits at its LEXICAL position, not unconditionally first: the
# __aa label sorts before __name__, so its value ('a' < 'z') decides the
# tie against the opposing metric-name order.
eval_ordered instant at 50m sort_by_label(label_replace(tie_pos, "__name__", "$1", "kind", "(.*)"), "x")
	zzz{__aa="a", kind="zzz", x="1"} 200
	aaa{__aa="z", kind="aaa", x="1"} 100

eval_ordered instant at 50m sort_by_label_desc(label_replace(tie_pos, "__name__", "$1", "kind", "(.*)"), "x")
	aaa{__aa="z", kind="aaa", x="1"} 100
	zzz{__aa="a", kind="zzz", x="1"} 200

clear

# --- __name__ as label_replace src/dst ------------------------------------
# (Adjudicated on #68: __name__ is readable and writable; upstream exempts
# label_replace/label_join from dropMetricName.)

load 5m
	rw_names{kind="foo", shared="x"}	1 2 3
	rw_names{kind="bar", shared="x"}	4 5 6

# Write __name__ from a capture.
eval instant at 0m label_replace(rw_names, "__name__", "$1", "kind", "(.*)")
	foo{kind="foo", shared="x"} 1
	bar{kind="bar", shared="x"} 4

# Read __name__ as src.
eval instant at 0m label_replace(rw_names, "copied", "$1", "__name__", "(.*)")
	rw_names{kind="foo", shared="x", copied="rw_names"} 1
	rw_names{kind="bar", shared="x", copied="rw_names"} 4

# An empty expansion into __name__ deletes the metric name.
eval instant at 0m label_replace(rw_names, "__name__", "", "kind", ".*")
	{kind="foo", shared="x"} 1
	{kind="bar", shared="x"} 4

# --- range identity semantics (plan v3 Δ4/Δ5, AC12) ------------------------
# Steps land at 0m/5m/10m; the 5m-step lookback window is left-open, so a
# sample at exactly t-5m is excluded — the gap rows below make the two
# source series step-disjoint.

load 5m
	rw{kind="one", shared="x"}	7 _ _
	rw{kind="two", shared="x"}	_ _ 9
	rw_overlap{kind="one", shared="x"}	1 1 1
	rw_overlap{kind="two", shared="x"}	2 2 2
	rw_names_disjoint{kind="foo", shared="x"}	1 _ _
	rw_names_disjoint{kind="bar", shared="x"}	_ _ 6

# (i) Same full identity at DISJOINT step times -> one merged series.
eval range from 0 to 10m step 5m label_replace(rw, "kind", "", "kind", ".*")
	rw{shared="x"} 7 _ 9

# (ii) Same full identity at an OVERLAPPING step -> the whole query fails
# with the upstream duplicate-labelset message.
eval_fail range from 0 to 10m step 5m label_replace(rw_overlap, "kind", "", "kind", ".*")
	expected_fail_message vector cannot contain metrics with the same labelset

# (iii) Equal non-name labels under DIFFERENT metric names -> two separate
# series, at overlapping steps...
eval range from 0 to 10m step 5m label_replace(label_replace(rw_names, "__name__", "$1", "kind", "(.*)"), "kind", "", "kind", ".*")
	foo{shared="x"} 1 2 3
	bar{shared="x"} 4 5 6

# ...and at disjoint steps (never merged, never a false collision).
eval range from 0 to 10m step 5m label_replace(label_replace(rw_names_disjoint, "__name__", "$1", "kind", "(.*)"), "kind", "", "kind", ".*")
	foo{shared="x"} 1 _ _
	bar{shared="x"} _ _ 6

clear

# --- absent --------------------------------------------------------------
# Bare-selector label synthesis: the shared createLabelsForAbsentFunction
# walk (functions.test:1700-1712).

eval instant at 50m absent(nonexistent)
	{} 1

eval instant at 50m absent(nonexistent{job="testjob", instance="testinstance", method=~".x"})
	{instance="testinstance", job="testjob"} 1

eval instant at 50m absent(nonexistent{job="testjob",job="testjob2",foo="bar"})
	{foo="bar"} 1

eval instant at 50m absent(nonexistent{job="testjob",job="testjob2",job="three",foo="bar"})
	{foo="bar"} 1

eval instant at 50m absent(nonexistent{job="testjob",job=~"testjob2",foo="bar"})
	{foo="bar"} 1

# Parentheses strip before the bare-selector special case (the upstream
# unwrapParenExpr walk — the label_replace paren case's sibling).
eval instant at 50m absent(((nonexistent{job="testjob"})))
	{job="testjob"} 1

# Computed arguments synthesize the EMPTY label set
# (functions.test:1735-1750; `a and b` stays planner-unsupported until
# M6-07's set operations).
eval instant at 50m absent(sum(nonexistent{job="testjob", instance="testinstance"}))
	{} 1

eval instant at 50m absent(max(nonexistent))
	{} 1

eval instant at 50m absent(nonexistent > 1)
	{} 1

eval instant at 50m absent(a + b)
	{} 1

eval instant at 50m absent(rate(nonexistent[5m]))
	{} 1

clear

# Don't return anything when there's something there
# (functions.test:1719-1727, minus the native-histogram rows).
load 5m
	http_requests{job="api-server", instance="0", group="production"}	0+10x10

eval instant at 50m absent(http_requests)

eval instant at 50m absent(sum(http_requests))

clear

# A range query evaluates absence per step: the only sample (t=0) is
# visible at step 0 and outside the left-open lookback window from 5m on.
load 5m
	sparse{job="x"}	1

eval range from 0 to 10m step 5m absent(sparse{job="x"})
	{job="x"} _ 1 1
