{
  "uid": "firehose-pulsusdb",
  "title": "Firehose → PulsusDB — Logs / Metrics / Traces",
  "description": "Local Grafana demo stack (deploy/e2e/compose.grafana.yaml): firehose's synthetic logs/metrics/traces as ingested and queried back through pulsusdb's Loki/Prometheus/Tempo-compat datasources (deploy/e2e/grafana/provisioning/datasources/*.yaml). Not the terraform-google-monitoring firehose-consumption.json dashboard — that one graphs Kafka broker throughput (bytesin/bytesout/lag per topic), which doesn't exist in this stack (firehose ships OTLP straight to the collector, no Kafka hop); this dashboard queries the signals themselves instead.",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["firehose", "pulsusdb", "demo"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Log lines/sec",
      "datasource": { "type": "loki", "uid": "pulsus-loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "pulsus-loki" },
          "expr": "sum(rate({service_name=\"firehose\"}[$__rate_interval]))",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg CPU utilization (fleet)",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "avg(system_cpu_utilization)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg memory utilization (fleet)",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "avg(system_memory_utilization)"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Checkout requests/sec (app metric)",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "sum(rate(app_checkout_request_count[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "firehose log stream",
      "datasource": { "type": "loki", "uid": "pulsus-loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "pulsus-loki" },
          "expr": "{service_name=\"firehose\"}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "CPU utilization by host (top 10)",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "topk(10, avg by (host_name) (system_cpu_utilization))",
          "legendFormat": "{{host_name}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Memory utilization by host (top 10)",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "topk(10, avg by (host_name) (system_memory_utilization))",
          "legendFormat": "{{host_name}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Network I/O by direction",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "sum by (direction) (rate(system_network_io[$__rate_interval]))",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Checkout requests/sec by region",
      "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "pulsus-prometheus" },
          "expr": "sum by (region) (rate(app_checkout_request_count[$__rate_interval]))",
          "legendFormat": "{{region}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 31,
      "type": "traces",
      "title": "firehose traces",
      "datasource": { "type": "tempo", "uid": "pulsus-tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "pulsus-tempo" },
          "queryType": "search",
          "filters": [
            {
              "id": "service-name",
              "type": "static",
              "tag": "resource.service.name",
              "operator": "=",
              "value": ["firehose"],
              "valueType": "string"
            }
          ],
          "limit": 20
        }
      ]
    }
  ]
}
