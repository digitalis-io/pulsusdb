<?xml version="1.0"?>
<!--
  Single-node clickhouse-keeper for the issue #5 2-shard CI fixture. One
  Raft voter is enough for a throwaway CI cluster (no HA requirement here);
  production Keeper quorums are a separate, later concern.

  `raft_configuration`'s `hostname` is the fixture's static `ipv4_address`
  (compose.yaml, 172.28.0.0/24), not a DNS alias — KISS directive on issue
  #5: no hostname resolution anywhere in this fixture, even though a
  single-voter Raft group never actually dials it.
-->
<clickhouse>
    <listen_host>0.0.0.0</listen_host>
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse-keeper/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse-keeper/coordination/snapshots</snapshot_storage_path>
        <!-- 4-letter-word commands (e.g. "ruok") are disabled by default;
             the compose healthcheck needs "ruok" whitelisted to report
             the container healthy. -->
        <four_letter_word_white_list>ruok,mntr,conf</four_letter_word_white_list>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>172.28.0.10</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>
</clickhouse>
