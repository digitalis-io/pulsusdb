{
  "_comment": "issue #33 M2 differential-accuracy corpus + query matrix (e2e/src/metrics.rs, e2e/src/corpus.rs). `{R}` in every query_matrix expr is replaced with this run's run_id label value at execution time. Tier sizing: `ci` sums to ~1,000 series (gates every PR inside e2e-single/e2e-cluster); `full` sums to ~10,000 series (the docs/features.md §7 acceptance criterion — closure evidence + nightly schedule + workflow_dispatch, PULSUS_E2E_METRICS_SCALE=full). Both tiers share the same 5 services / 8 histogram bounds / 40-sample window so every query_matrix construct is exercised identically at either scale (correctness is scale-invariant, per the architect plan).",
  "seed": 424242,
  "step_ms": 15000,
  "sample_count": 40,
  "histogram_bounds": [0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1.0],
  "ci": {
    "services": 5,
    "gauge_instances": 23,
    "gauge_slots": 3,
    "counter_instances": 68,
    "histogram_instances": 6
  },
  "full": {
    "services": 5,
    "gauge_instances": 225,
    "gauge_slots": 3,
    "counter_instances": 680,
    "histogram_instances": 58
  },
  "query_matrix": [
    { "expr": "mem_usage_bytes{run_id=\"{R}\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\",service=\"svc-3\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\",service!=\"svc-3\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\",service=~\"svc-(1|2)\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\",instance!~\"inst-0.*\"}", "modes": ["instant", "range"] },

    { "expr": "mem_usage_bytes{run_id=\"{R}\"} offset 1m", "modes": ["instant", "range"] },

    { "expr": "rate(requests_total{run_id=\"{R}\"}[2m])", "modes": ["instant", "range"] },
    { "expr": "irate(requests_total{run_id=\"{R}\"}[1m])", "modes": ["instant", "range"] },
    { "expr": "increase(requests_total{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "delta(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },

    { "expr": "avg_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "min_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "max_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "sum_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "count_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },

    { "expr": "sum by(service)(rate(requests_total{run_id=\"{R}\"}[2m]))", "modes": ["instant", "range"] },
    { "expr": "avg without(instance)(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "min by(service)(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "max by(service)(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "count by(service)(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "topk(3, sum by(service)(rate(requests_total{run_id=\"{R}\"}[2m])))", "modes": ["instant", "range"] },
    { "expr": "bottomk(3, sum by(service)(rate(requests_total{run_id=\"{R}\"}[2m])))", "modes": ["instant", "range"] },

    { "expr": "mem_usage_bytes{run_id=\"{R}\"} * 2", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\"} > bool 5e8", "modes": ["instant", "range"] },
    {
      "expr": "sum by(service)(rate(requests_total{run_id=\"{R}\"}[2m])) + on(service) sum by(service)(rate(requests_total{run_id=\"{R}\"}[5m]))",
      "modes": ["instant", "range"]
    },
    {
      "_comment": "matching-drop case (architect plan §6, substituting this corpus's own `slot` dimension for the plan's illustrative `method` label — the corpus has no `method` label; deviation noted in the issue #33 implementation notes): left selects every instance at slot-0 for svc-1, right pins a single instance at slot-1 — `ignoring(slot)` matches on (service,instance), so every left-side series without a slot-1 counterpart at the *same* instance is silently dropped from the output, leaving exactly one result series.",
      "expr": "mem_usage_bytes{run_id=\"{R}\",service=\"svc-1\",slot=\"slot-0\"} + ignoring(slot) mem_usage_bytes{run_id=\"{R}\",service=\"svc-1\",slot=\"slot-1\",instance=\"inst-000\"}",
      "modes": ["instant", "range"]
    },

    {
      "expr": "histogram_quantile(0.9, sum by(le)(rate(request_duration_seconds_bucket{run_id=\"{R}\"}[5m])))",
      "modes": ["instant", "range"]
    },
    {
      "expr": "histogram_quantile(0.5, rate(request_duration_seconds_bucket{run_id=\"{R}\",service=\"svc-3\"}[5m]))",
      "modes": ["instant", "range"]
    },

    { "expr": "abs(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "ceil(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "floor(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "sqrt(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "sgn(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "deg(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "rad(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "clamp(mem_usage_bytes{run_id=\"{R}\"}, 3e8, 7e8)", "modes": ["instant", "range"] },
    { "expr": "clamp_min(mem_usage_bytes{run_id=\"{R}\"}, 5e8)", "modes": ["instant", "range"] },
    { "expr": "clamp_max(mem_usage_bytes{run_id=\"{R}\"}, 5e8)", "modes": ["instant", "range"] },
    { "expr": "round(mem_usage_bytes{run_id=\"{R}\"}, 1000)", "modes": ["instant", "range"] },
    { "expr": "time()", "modes": ["instant", "range"] },
    { "expr": "vector(time())", "modes": ["instant", "range"] },
    { "expr": "timestamp(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "timestamp(mem_usage_bytes{run_id=\"{R}\"} offset 1m)", "modes": ["instant", "range"] },
    { "expr": "scalar(sum(mem_usage_bytes{run_id=\"{R}\"}))", "modes": ["instant", "range"] },
    { "expr": "vector(scalar(sum(mem_usage_bytes{run_id=\"{R}\"})))", "modes": ["instant", "range"] },
    { "expr": "year(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "month(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "day_of_month(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "day_of_week(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "day_of_year(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "days_in_month(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "hour(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "minute(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "month()", "modes": ["instant", "range"] },

    { "expr": "idelta(mem_usage_bytes{run_id=\"{R}\"}[2m])", "modes": ["instant", "range"] },
    { "expr": "resets(requests_total{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "changes(requests_total{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "last_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "present_over_time(mem_usage_bytes{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },
    { "expr": "absent_over_time(nonexistent_metric{run_id=\"{R}\"}[5m])", "modes": ["instant", "range"] },

    { "expr": "label_replace(mem_usage_bytes{run_id=\"{R}\"}, \"rewritten\", \"$1-copy\", \"service\", \"svc-(.*)\")", "modes": ["instant", "range"] },
    { "expr": "label_join(mem_usage_bytes{run_id=\"{R}\"}, \"joined\", \"-\", \"service\", \"instance\")", "modes": ["instant", "range"] },
    { "expr": "absent(nonexistent_metric{run_id=\"{R}\"})", "modes": ["instant", "range"] },

    { "expr": "group by(service)(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "group without(instance)(rate(requests_total{run_id=\"{R}\"}[2m]))", "modes": ["instant", "range"] },
    { "expr": "count_values(\"v\", mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },

    { "expr": "mem_usage_bytes{run_id=\"{R}\"} and ignoring(slot) requests_total{run_id=\"{R}\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\"} or requests_total{run_id=\"{R}\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\"} unless requests_total{run_id=\"{R}\"}", "modes": ["instant", "range"] },
    { "expr": "requests_total{run_id=\"{R}\"} unless on(instance, run_id) mem_usage_bytes{run_id=\"{R}\"}", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\"} / on(service, run_id) group_left max by(service, run_id)(mem_usage_bytes{run_id=\"{R}\"})", "modes": ["instant", "range"] },
    { "expr": "mem_usage_bytes{run_id=\"{R}\"} * on(service, run_id) group_left(team) label_replace(max by(service, run_id)(mem_usage_bytes{run_id=\"{R}\"}), \"team\", \"$1\", \"service\", \"svc-(.*)\")", "modes": ["instant", "range"] },
    { "expr": "label_replace(max by(service, run_id)(mem_usage_bytes{run_id=\"{R}\"}), \"team\", \"$1\", \"service\", \"svc-(.*)\") * on(service, run_id) group_right(team) mem_usage_bytes{run_id=\"{R}\"}", "modes": ["instant", "range"] },

    { "expr": "sum by(__name__)(rate(requests_total{run_id=\"{R}\"}[2m]))", "modes": ["instant", "range"] },
    { "expr": "sum by(__name__)(mem_usage_bytes{run_id=\"{R}\",service=\"svc-3\"} or rate(requests_total{run_id=\"{R}\",service=\"svc-3\"}[2m]))", "modes": ["instant", "range"] },
    { "expr": "sum by(__name__)(mem_usage_bytes{run_id=\"{R}\",service=\"svc-1\"} or (mem_usage_bytes{run_id=\"{R}\",service=\"svc-2\"} * 1))", "modes": ["instant", "range"] },
    { "expr": "(mem_usage_bytes{run_id=\"{R}\",service=\"svc-0\",instance=\"inst-000\",slot=\"slot-1\"} > 200000150) or (mem_usage_bytes{run_id=\"{R}\",service=\"svc-0\",instance=\"inst-000\",slot=\"slot-1\"} * 1)", "modes": ["instant", "range"] },
    { "expr": "sum by(__name__)(label_replace(rate(requests_total{run_id=\"{R}\",service=\"svc-3\"}[2m]) or delta(mem_usage_bytes{run_id=\"{R}\",service=\"svc-3\"}[5m]), \"__name__\", \"$1\", \"__name__\", \"(.+)\"))", "modes": ["instant", "range"] }
  ]
